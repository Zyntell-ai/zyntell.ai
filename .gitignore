# ════════════════════════════════════════════════════════════════
#  ZYNTELL — .gitignore
# ════════════════════════════════════════════════════════════════


# ── Environment & Secrets ─────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
.env.development
*.env

# Keep the example template (safe to commit)
!.env.example
config.js

# ── Dependencies ──────────────────────────────────────────────────
node_modules/
.npm
.yarn/
.pnp.*


# ── Build Outputs ─────────────────────────────────────────────────
dist/
build/
.next/
.nuxt/
.output/
out/
.vite/
.cache/


# ── OS Files ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# ── Editor & IDE ──────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*.bak


# ── Logs ──────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ── Testing & Coverage ────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/
test-results/
playwright-report/


# ── Temporary Files ───────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.backup
*.orig
.cache/
tmp/
temp/


# ── Supabase local dev ────────────────────────────────────────────
.supabase/
supabase/.temp/


# ── Misc ──────────────────────────────────────────────────────────
*.zip
*.tar.gz
*.tgz
.vercel
.netlify