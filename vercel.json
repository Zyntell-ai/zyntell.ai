{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "zyntell.in"
        }
      ],
      "destination": "https://www.zyntell.in/$1",
      "permanent": true
    }
  ],
  "buildCommand": "node generate-config.js",
  "outputDirectory": "."
}
